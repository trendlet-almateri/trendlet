# Copy to .env.local and fill in real values. NEVER commit .env.local.

# ── Supabase (project: kfrjqpjprvvsibwmrqph "Trendlet" eu-west-1) ─────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Pooler URL (port 6543, transaction mode) — runtime queries
DATABASE_URL=postgres://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Direct URL (port 5432) — migrations only
DIRECT_URL=postgres://postgres.YOUR-PROJECT-REF:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ── Shopify (live) ────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_WEBHOOK_SECRET=

# ── AI (deferred; see /setup/integrations for live status) ────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Twilio WhatsApp (live) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+966XXXXXXXXX

# ── DHL Express (mock unless DHL_API_KEY is set) ──────────────────────────────
DHL_BASE_URL=https://express.api.dhl.com/mydhlapi
# DHL_API_KEY=

# ── Hubstaff (mock unless HUBSTAFF_TOKEN is set) ──────────────────────────────
# HUBSTAFF_TOKEN=

# ── Resend (mock unless RESEND_API_KEY is set) ────────────────────────────────
# RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app
NEXT_PUBLIC_APP_ENV=production
NEXTAUTH_SECRET=

# Optional: override the single-store id used by the Shopify webhook handler.
# Defaults to the seeded Trendslet store; set this only when going multi-store.
# TRENDLET_STORE_ID=

# ── Cron protection (required for /api/cron/* in production) ──────────────────
# Generate a long random string: openssl rand -base64 32
CRON_SECRET=

# ── Email (deferred wiring) ───────────────────────────────────────────────────
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FROM_NAME=Trendslet Operations
